# Django ortam degiskenleri ornegi.
# Bu dosyayi ".env" olarak kopyalayin ve gercek degerlerle doldurun.
# .env dosyasini ASLA versiyon kontrolune eklemeyin.

# Zorunlu: Django gizli anahtari. Uygulama bu deger olmadan baslamaz.
# Yeni bir anahtar uretmek icin:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=YOUR_SECRET_KEY_HERE

# Hata ayiklama modu. Production'da daima False birakin.
DJANGO_DEBUG=False

# Virgulle ayrilmis izinli host listesi.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
